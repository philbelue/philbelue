# Best Buy Stock Checker Configuration

# Product URL (exact product page preferred)
BESTBUY_URL=https://www.bestbuy.com/site/apple-mac-studio-desktop-apple-m4-max-chip-48gb-memory-512gb-ssd-latest-model-silver/6604920.p?skuId=6604920

# SKU ID (used as strongest identifier)
BESTBUY_SKU=6604920

# Location
ZIP_CODE=28217
STORE_NAME=Concord Mills

# Polling
CHECK_INTERVAL_SECONDS=300
JITTER_MIN=15
JITTER_MAX=45

# Email (SMTP)
SMTP_ENABLED=false
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your-email@gmail.com
SMTP_PASSWORD=your-app-password
SMTP_TO=your-email@gmail.com

# Discord
DISCORD_ENABLED=false
DISCORD_WEBHOOK_URL=https://discord.com/api/webhooks/your-webhook-url

# Twilio SMS
TWILIO_ENABLED=false
TWILIO_ACCOUNT_SID=your-account-sid
TWILIO_AUTH_TOKEN=your-auth-token
TWILIO_FROM_NUMBER=+1XXXXXXXXXX
TWILIO_TO_NUMBER=+17047736226

# Desktop notification (macOS)
DESKTOP_NOTIFY=true

# Sound alert
SOUND_ALERT=true

# Logging
LOG_FILE=stock_checker.log
STATE_FILE=state.json
CSV_LOG_FILE=stock_log.csv
